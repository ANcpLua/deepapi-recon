{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "deepapi-contract-audit",
          "informationUri": "https://github.com/ANcpLua/deepapi-recon",
          "version": "1.0.0",
          "rules": [
            {
              "id": "deepapi-client/idempotency-key-not-reused",
              "name": "IdempotencyKeyNotReused",
              "shortDescription": {
                "text": "Retry mints a new Idempotency-Key, breaking same-key idempotency"
              },
              "fullDescription": {
                "text": "On a retryable error the client generates a fresh Idempotency-Key instead of reusing it. For the codes the DeepAPI error table marks \"retry with the same key\" (rate_limit_exceeded, idempotency_conflict, every *_request_failed), the retry is treated as a brand-new operation \u2014 risking duplicate execution and double billing."
              },
              "helpUri": "https://deepapi.co/llms.txt",
              "help": {
                "text": "On a retryable error the client generates a fresh Idempotency-Key instead of reusing it. For the codes the DeepAPI error table marks \"retry with the same key\" (rate_limit_exceeded, idempotency_conflict, every *_request_failed), the retry is treated as a brand-new operation \u2014 risking duplicate execution and double billing.\n\nRecommendation: Generate the Idempotency-Key once and reuse it across retries; only rotate it for upstream_rate_limited / request_failed, which the table marks new-key."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": [
                  "security",
                  "reliability",
                  "deepapi-contract"
                ],
                "security-severity": "8.1"
              }
            },
            {
              "id": "deepapi-client/unbounded-retry-recursion",
              "name": "UnboundedRetryRecursion",
              "shortDescription": {
                "text": "Unbounded retry recursion on persistent retryable errors"
              },
              "fullDescription": {
                "text": "The retry path recurses with no attempt bound. A persistently-retryable error (e.g. a sustained 502 *_request_failed) recurses until the stack overflows \u2014 a self-inflicted denial of service."
              },
              "helpUri": "https://deepapi.co/llms.txt",
              "help": {
                "text": "The retry path recurses with no attempt bound. A persistently-retryable error (e.g. a sustained 502 *_request_failed) recurses until the stack overflows \u2014 a self-inflicted denial of service.\n\nRecommendation: Bound retries with a max-attempts counter and give up with a clear error."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": [
                  "security",
                  "reliability",
                  "deepapi-contract"
                ],
                "security-severity": "8.1"
              }
            },
            {
              "id": "deepapi-client/error-fix-ignored",
              "name": "ErrorFixIgnored",
              "shortDescription": {
                "text": "invalid_request self-correction (error.fix) is ignored"
              },
              "fullDescription": {
                "text": "invalid_request responses carry error.fix (bodySchema, requiredFields, exampleBody) for automatic self-correction. The client discards it and aborts, forcing a human round-trip instead of a schema-guided retry."
              },
              "helpUri": "https://deepapi.co/llms.txt",
              "help": {
                "text": "invalid_request responses carry error.fix (bodySchema, requiredFields, exampleBody) for automatic self-correction. The client discards it and aborts, forcing a human round-trip instead of a schema-guided retry.\n\nRecommendation: On invalid_request, rebuild the body from error.fix.exampleBody and retry with a new Idempotency-Key."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "tags": [
                  "security",
                  "reliability",
                  "deepapi-contract"
                ],
                "security-severity": "5.5"
              }
            }
          ]
        }
      },
      "automationDetails": {
        "id": "deepapi-contract-audit/"
      },
      "results": [
        {
          "ruleId": "deepapi-client/idempotency-key-not-reused",
          "ruleIndex": 0,
          "level": "error",
          "message": {
            "text": "On a retryable error the client generates a fresh Idempotency-Key instead of reusing it. For the codes the DeepAPI error table marks \"retry with the same key\" (rate_limit_exceeded, idempotency_conflict, every *_request_failed), the retry is treated as a brand-new operation \u2014 risking duplicate execution and double billing.\n\nRecommendation: Generate the Idempotency-Key once and reuse it across retries; only rotate it for upstream_rate_limited / request_failed, which the table marks new-key."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "tests/_naive_client.py"
                },
                "region": {
                  "startLine": 45,
                  "endLine": 45
                }
              }
            }
          ],
          "partialFingerprints": {
            "deepapiContractRule/v1": "deepapi-client/idempotency-key-not-reused"
          }
        },
        {
          "ruleId": "deepapi-client/unbounded-retry-recursion",
          "ruleIndex": 1,
          "level": "error",
          "message": {
            "text": "The retry path recurses with no attempt bound. A persistently-retryable error (e.g. a sustained 502 *_request_failed) recurses until the stack overflows \u2014 a self-inflicted denial of service.\n\nRecommendation: Bound retries with a max-attempts counter and give up with a clear error."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "tests/_naive_client.py"
                },
                "region": {
                  "startLine": 59,
                  "endLine": 59
                }
              }
            }
          ],
          "partialFingerprints": {
            "deepapiContractRule/v1": "deepapi-client/unbounded-retry-recursion"
          }
        },
        {
          "ruleId": "deepapi-client/error-fix-ignored",
          "ruleIndex": 2,
          "level": "warning",
          "message": {
            "text": "invalid_request responses carry error.fix (bodySchema, requiredFields, exampleBody) for automatic self-correction. The client discards it and aborts, forcing a human round-trip instead of a schema-guided retry.\n\nRecommendation: On invalid_request, rebuild the body from error.fix.exampleBody and retry with a new Idempotency-Key."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "tests/_naive_client.py"
                },
                "region": {
                  "startLine": 62,
                  "endLine": 62
                }
              }
            }
          ],
          "partialFingerprints": {
            "deepapiContractRule/v1": "deepapi-client/error-fix-ignored"
          }
        }
      ]
    }
  ]
}